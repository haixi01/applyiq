# ApplyIQ — Environment Configuration
# Copy this file to .env and fill in your values.

# Langflow server URL
LANGFLOW_BASE_URL=http://127.0.0.1:7860

# Flow ID from Langflow
LANGFLOW_FLOW_ID=9dd9a257-0e88-4397-bd19-1a9b51f1f23d

# --- Auth (use ONE of the options below) ---

# Option A: API key (from Langflow UI → Settings → API Keys)
# LANGFLOW_API_KEY=sk-...

# Option B: Username/password login (defaults shown)
LANGFLOW_USERNAME=langflow
LANGFLOW_PASSWORD=langflow
